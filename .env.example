# Configuration Example
# Replace placeholder values with actual secure configuration
# DO NOT commit sensitive values to version control

# JWT Configuration
JWT_PUBLIC_KEY=           # Required: Public key for JWT verification (file path or content)
JWT_PRIVATE_KEY=          # Required: Private key for JWT signing (file path or content)
JWT_ISSUER=              # Required: Issuer claim for JWT validation
JWT_AUDIENCE=            # Required: Audience claim for JWT validation
JWT_EXPIRY=1h            # Optional: Token expiration time (default: 1h)

# Access Control Configuration
ALLOWED_REDIRECT_HOSTS=   # Required: Comma-separated list of allowed redirect hostnames
ALLOWED_ACCOUNTING_IPS=   # Required: Comma-separated list of allowed IP addresses for accounting access

# Cryptographic Settings
HMAC_SECRET=             # Required: Secret key for HMAC operations
HASH_ALGORITHM=sha256    # Optional: Hash algorithm (default: sha256)

# Security Notice
# 1. Replace empty values with your secure configuration
# 2. Never commit actual secrets or keys to version control
# 3. Use appropriate key lengths and entropy for production
# 4. Rotate secrets regularly according to security policy
